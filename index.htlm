<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Infographic - Cuộc thi ảnh Nét đẹp lao động</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Roboto', sans-serif; }
        .font-heading { font-family: 'Montserrat', sans-serif; }
        .bg-pattern {
            background-color: #005A9C;
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }
        .footer-bg { background-color: #1a252f; }
        .ai-glow { box-shadow: 0 0 15px rgba(59, 130, 246, 0.4); }
        @media print { .no-print { display: none; } }
        .animate-fade-in { animation: fadeIn 0.5s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .loading-spinner { animation: spin 1s linear infinite; }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    </style>
</head>
<body class="bg-slate-100 py-8 px-4 flex flex-col items-center min-h-screen">

    <!-- Thanh công cụ -->
    <div class="max-w-2xl w-full mb-6 flex gap-4 no-print text-sm">
        <button onclick="downloadInfographic()" class="flex-1 bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-6 rounded-xl shadow-lg flex items-center justify-center gap-2 transition-all transform hover:scale-105">
            <i class="fas fa-file-image text-xl"></i>
            Tải ảnh Infographic (PNG)
        </button>
    </div>

    <!-- Container Infographic chính -->
    <div id="infographic-main" class="max-w-2xl w-full bg-white rounded-3xl shadow-2xl overflow-hidden relative border border-gray-200">
        <div class="bg-pattern text-white text-center py-10 px-6 relative">
            <div class="absolute top-4 left-4 bg-white/20 px-3 py-1 rounded-full text-[10px] font-bold tracking-wider uppercase">
                Công đoàn Ban Khai thác mạng
            </div>
            <i class="fas fa-camera-retro text-5xl mb-4 text-blue-200 opacity-90"></i>
            <h2 class="font-heading text-xl md:text-2xl font-semibold mb-2 uppercase tracking-wide text-blue-100">Phát động cuộc thi ảnh</h2>
            <h1 class="font-heading text-3xl md:text-5xl font-extrabold leading-tight mb-4 text-yellow-300 drop-shadow-md">
                NÉT ĐẸP TRONG LAO ĐỘNG <br/> <span class="text-white text-2xl md:text-4xl">& CUỘC SỐNG GIA ĐÌNH</span>
            </h1>
        </div>

        <div class="flex flex-col md:flex-row bg-blue-50 border-b border-blue-100">
            <div class="flex-1 py-4 px-6 border-b md:border-b-0 md:border-r border-blue-200 flex items-center justify-center gap-3">
                <div class="bg-blue-600 text-white p-3 rounded-full h-10 w-10 flex items-center justify-center shadow">
                    <i class="far fa-calendar-alt"></i>
                </div>
                <div>
                    <p class="text-[10px] text-gray-500 uppercase font-bold">Thời gian nhận bài</p>
                    <p class="font-heading font-bold text-blue-800 text-sm">08/5 - 18/5/2026</p>
                </div>
            </div>
            <div class="flex-1 py-4 px-6 flex items-center justify-center gap-3">
                <div class="bg-blue-600 text-white p-3 rounded-full h-10 w-10 flex items-center justify-center shadow">
                    <i class="fas fa-users"></i>
                </div>
                <div>
                    <p class="text-[10px] text-gray-500 uppercase font-bold">Đối tượng</p>
                    <p class="font-heading font-bold text-blue-800 text-sm">Toàn thể CBNV Ban KTM</p>
                </div>
            </div>
        </div>

        <div class="py-6 px-6 md:px-10 bg-white border-t border-gray-100">
            <h3 class="font-heading text-lg font-bold text-[#1e293b] mb-4 flex items-center gap-2 uppercase tracking-wide">
                <i class="fas fa-file-contract text-blue-600"></i> Yêu cầu tác phẩm
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-3 text-[11px] text-gray-700">
                <div class="flex items-start gap-2"><i class="fas fa-check text-green-500 mt-1"></i><span>Định dạng: .png hoặc .jpg; tối thiểu 1.920 pixel.</span></div>
                <div class="flex items-start gap-2"><i class="fas fa-check text-green-500 mt-1"></i><span>Dung lượng tối đa 10MB. Không dùng ảnh AI.</span></div>
                <div class="flex items-start gap-2"><i class="fas fa-check text-green-500 mt-1"></i><span>Mỗi CĐBP gửi tối đa 06 tác phẩm (3 LĐ & 3 GĐ).</span></div>
                <div class="flex items-start gap-2"><i class="fas fa-check text-green-500 mt-1"></i><span>Ưu tiên trang phục thương hiệu VNPT, lịch sự.</span></div>
            </div>
        </div>

        <div class="footer-bg text-white py-8 px-8 md:px-12 text-center">
            <p class="text-blue-400 font-bold text-xs uppercase tracking-tighter">Hỗ trợ kỹ thuật: Đ/c Hà Minh Hoàng - 0914.746.789</p>
        </div>
    </div>

    <!-- HỆ THỐNG NỘP BÀI -->
    <div class="max-w-2xl w-full mt-10 space-y-6 no-print">
        <div class="bg-white rounded-3xl shadow-xl overflow-hidden border-2 border-blue-500 ai-glow">
            <div class="bg-blue-600 p-4 text-white flex items-center justify-between">
                <h3 class="font-heading font-bold uppercase tracking-widest flex items-center gap-2">
                    <i class="fas fa-magic"></i> Trợ lý AI - Nộp bài trực tuyến
                </h3>
                <div class="text-[10px] bg-blue-800 px-2 py-1 rounded">CLOUD V2.1</div>
            </div>
            
            <div class="p-6 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="text-[10px] font-bold text-gray-400 uppercase mb-1 block">Tên tác giả *</label>
                        <input id="author-name" type="text" placeholder="Họ và tên..." class="w-full px-4 py-2 border border-gray-200 rounded-xl outline-none focus:border-blue-500 transition-colors">
                    </div>
                    <div>
                        <label class="text-[10px] font-bold text-gray-400 uppercase mb-1 block">CĐBP *</label>
                        <select id="author-unit" class="w-full px-4 py-2 border border-gray-200 rounded-xl outline-none focus:border-blue-500 bg-white transition-colors">
                            <option value="">-- Chọn đơn vị --</option>
                            <option value="NOC1">NOC1</option><option value="NOC2">NOC2</option><option value="NOC3">NOC3</option>
                            <option value="KHKT">KHKT</option><option value="NSHC">NSHC</option><option value="ANM">ANM</option>
                            <option value="SOC">SOC</option><option value="NMC">NMC</option>
                        </select>
                    </div>
                </div>

                <div id="drop-area" class="border-2 border-dashed border-blue-100 rounded-2xl p-8 text-center bg-blue-50/20 cursor-pointer hover:bg-blue-50 transition-all group">
                    <input type="file" id="file-input" accept="image/*" class="hidden" onchange="handleFileUpload(this)">
                    <label for="file-input" class="cursor-pointer block">
                        <i class="fas fa-cloud-upload-alt text-4xl text-blue-400 mb-2 group-hover:scale-110 transition-transform"></i>
                        <p class="text-sm text-gray-600 font-medium">Nhấn để chọn hoặc kéo thả ảnh dự thi</p>
                    </label>
                    <div id="image-preview" class="mt-4 hidden">
                        <img id="preview-img" src="" class="max-h-64 mx-auto rounded-xl shadow-lg border-4 border-white">
                    </div>
                </div>

                <div id="ai-analysis" class="hidden space-y-4 animate-fade-in bg-slate-50 p-5 rounded-2xl border border-slate-100">
                    <div>
                        <label class="text-[10px] font-bold text-gray-400 uppercase mb-1 block">Tiêu đề tác phẩm dự kiến</label>
                        <input id="photo-title" type="text" placeholder="Tên tác phẩm..." class="w-full bg-white px-3 py-2 border border-gray-200 rounded-lg text-sm font-bold shadow-sm focus:border-blue-400 outline-none">
                    </div>
                    <div>
                        <label class="text-[10px] font-bold text-gray-400 uppercase mb-1 block">Lời bình (AI gợi ý)</label>
                        <textarea id="photo-caption" rows="3" placeholder="Lời bình..." class="w-full bg-white px-3 py-2 border border-gray-200 rounded-lg text-sm shadow-sm focus:border-blue-400 outline-none"></textarea>
                    </div>
                </div>

                <button onclick="submitEntry()" id="btn-submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-2xl shadow-xl transition-all flex items-center justify-center gap-3 transform active:scale-95">
                    <i class="fas fa-paper-plane"></i> GỬI BÀI DỰ THI NGAY
                </button>
            </div>
        </div>
    </div>

    <!-- Modal thành công -->
    <div id="success-modal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-3xl p-10 max-w-sm w-full text-center shadow-2xl animate-fade-in">
            <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center text-3xl mx-auto mb-4">
                <i class="fas fa-check"></i>
            </div>
            <h4 class="text-xl font-bold mb-2 text-slate-800">Đã nhận bài thi!</h4>
            <p class="text-slate-500 text-sm mb-6 leading-relaxed">Tác phẩm của đồng chí đang được tải lên Google Drive của Ban Tổ chức. Cảm ơn đồng chí đã tham gia!</p>
            <button onclick="location.reload()" class="w-full bg-blue-600 text-white py-3 rounded-xl hover:bg-blue-700 shadow-lg font-bold">Nộp bài khác</button>
        </div>
    </div>

    <script>
        // API KEY và URL APPS SCRIPT MỚI
        const apiKey = ""; 
        const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbyfwUKyJwWB8GH6s8QWE2RaMJ4prfbWfiVnWSYfQ9BGWhhWQcdQWgodEfboqrMVMXQQ/exec"; 
        
        let currentImageData = null;

        // Hàm gọi AI phân tích ảnh
        async function callGemini(prompt, isImage = false, imageData = null) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            let contents = [{ parts: [{ text: prompt }] }];
            if (isImage && imageData) {
                contents[0].parts.push({ inlineData: { mimeType: "image/png", data: imageData.split(',')[1] } });
            }
            try {
                const response = await fetch(url, {
                    method: 'POST',
                    body: JSON.stringify({
                        contents: contents,
                        generationConfig: { responseMimeType: "application/json" },
                        systemInstruction: { parts: [{ text: "Bạn là trợ lý cho cuộc thi ảnh VNPT KTM. Hãy phân tích ảnh và trả về JSON: { title: 'Tiêu đề ngắn gọn', caption: 'Lời bình ý nghĩa về lao động hoặc gia đình' }. Ngôn ngữ: Tiếng Việt." }] }
                    })
                });
                const res = await response.json();
                return JSON.parse(res.candidates[0].content.parts[0].text);
            } catch (e) {
                return { title: "Khoảnh khắc Ban KTM", caption: "Bức ảnh dự thi đầy ý nghĩa của cán bộ nhân viên." };
            }
        }

        // Xử lý khi chọn file
        async function handleFileUpload(input) {
            const file = input.files[0];
            if (!file) return;

            if (file.size > 10 * 1024 * 1024) {
                alert("Dung lượng ảnh vượt quá 10MB. Vui lòng chọn ảnh khác.");
                input.value = "";
                return;
            }

            const reader = new FileReader();
            reader.onload = async (e) => {
                currentImageData = e.target.result;
                document.getElementById('preview-img').src = currentImageData;
                document.getElementById('image-preview').classList.remove('hidden');
                document.getElementById('ai-analysis').classList.remove('hidden');
                
                document.getElementById('photo-title').placeholder = "AI đang phân tích ảnh...";
                document.getElementById('photo-caption').placeholder = "AI đang soạn lời bình...";
                
                const analysis = await callGemini("Hãy gợi ý tiêu đề và lời bình cho bức ảnh dự thi này.", true, currentImageData);
                document.getElementById('photo-title').value = analysis.title;
                document.getElementById('photo-caption').value = analysis.caption;
            };
            reader.readAsDataURL(file);
        }

        // Gửi bài thi
        async function submitEntry() {
            const name = document.getElementById('author-name').value.trim();
            const unit = document.getElementById('author-unit').value;
            const title = document.getElementById('photo-title').value.trim();
            const caption = document.getElementById('photo-caption').value.trim();
            const btn = document.getElementById('btn-submit');

            if(!name || !unit || !currentImageData || !title) {
                alert("Vui lòng điền đủ: Họ tên, Đơn vị, Tiêu đề và chọn Ảnh!");
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner loading-spinner"></i> ĐANG TẢI LÊN DRIVE...';

            try {
                const payload = JSON.stringify({
                    author: name,
                    unit: unit,
                    title: title,
                    caption: caption,
                    image: currentImageData
                });

                // Mode no-cors để gửi đến Google Apps Script
                await fetch(GOOGLE_SCRIPT_URL, {
                    method: 'POST',
                    mode: 'no-cors',
                    cache: 'no-cache',
                    headers: { 'Content-Type': 'application/json' },
                    body: payload
                });

                // Giả định thành công sau 3 giây vì no-cors không trả về phản hồi
                setTimeout(() => {
                    document.getElementById('success-modal').classList.remove('hidden');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-paper-plane"></i> GỬI BÀI DỰ THI';
                }, 3000);

            } catch (e) {
                alert("Đã xảy ra lỗi hệ thống: " + e.toString());
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-paper-plane"></i> GỬI BÀI DỰ THI';
            }
        }

        function downloadInfographic() {
            const element = document.getElementById('infographic-main');
            html2canvas(element, { 
                scale: 2, 
                useCORS: true,
                allowTaint: true
            }).then(canvas => {
                const link = document.createElement('a');
                link.download = 'CuocThiAnh-KTM-2026.png';
                link.href = canvas.toDataURL('image/png');
                link.click();
            });
        }
    </script>
</body>
</html>
