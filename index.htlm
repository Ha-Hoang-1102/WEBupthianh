<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Infographic - Cuộc thi ảnh Nét đẹp lao động</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Roboto', sans-serif; }
        .font-heading { font-family: 'Montserrat', sans-serif; }
        .bg-pattern {
            background-color: #005A9C;
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }
        .footer-bg { background-color: #1a252f; }
        .ai-glow { box-shadow: 0 0 15px rgba(59, 130, 246, 0.4); }
        @media print { .no-print { display: none; } }
        .animate-fade-in { animation: fadeIn 0.5s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        /* Hiệu ứng loading cho nút gửi */
        .loading { cursor: not-allowed; opacity: 0.7; }
    </style>
</head>
<body class="bg-slate-100 py-8 px-4 flex flex-col items-center min-h-screen">

    <!-- Thanh công cụ hỗ trợ -->
    <div class="max-w-2xl w-full mb-6 flex gap-4 no-print text-sm">
        <button onclick="downloadInfographic()" class="flex-1 bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-6 rounded-xl shadow-lg flex items-center justify-center gap-2 transition-all transform hover:scale-105">
            <i class="fas fa-file-image text-xl"></i>
            Tải ảnh Infographic (PNG)
        </button>
    </div>

    <!-- Container Infographic chính -->
    <div id="infographic-main" class="max-w-2xl w-full bg-white rounded-3xl shadow-2xl overflow-hidden relative">
        
        <!-- Header Section -->
        <div class="bg-pattern text-white text-center py-10 px-6 relative">
            <div class="absolute top-4 left-4 bg-white/20 px-3 py-1 rounded-full text-[10px] font-bold tracking-wider uppercase">
                Công đoàn Ban Khai thác mạng
            </div>
            <i class="fas fa-camera-retro text-5xl mb-4 text-blue-200 opacity-90"></i>
            <h2 class="font-heading text-xl md:text-2xl font-semibold mb-2 uppercase tracking-wide text-blue-100">Phát động cuộc thi ảnh</h2>
            <h1 class="font-heading text-3xl md:text-5xl font-extrabold leading-tight mb-4 text-yellow-300 drop-shadow-md">
                NÉT ĐẸP TRONG LAO ĐỘNG <br/> <span class="text-white text-2xl md:text-4xl">& CUỘC SỐNG GIA ĐÌNH</span>
            </h1>
            <p class="text-blue-100 text-sm md:text-base max-w-lg mx-auto mb-4 italic">
                "Tôn vinh tinh thần cống hiến và giá trị hạnh phúc gia đình VNPT"
            </p>
        </div>

        <!-- Timeline & Target -->
        <div class="flex flex-col md:flex-row bg-blue-50 border-b border-blue-100">
            <div class="flex-1 py-4 px-6 border-b md:border-b-0 md:border-r border-blue-200 flex items-center justify-center gap-3">
                <div class="bg-blue-600 text-white p-3 rounded-full h-10 w-10 flex items-center justify-center shadow">
                    <i class="far fa-calendar-alt"></i>
                </div>
                <div>
                    <p class="text-[10px] text-gray-500 uppercase font-bold">Thời gian nhận bài</p>
                    <p class="font-heading font-bold text-blue-800">08/5 - 18/5/2026</p>
                </div>
            </div>
            <div class="flex-1 py-4 px-6 flex items-center justify-center gap-3">
                <div class="bg-blue-600 text-white p-3 rounded-full h-10 w-10 flex items-center justify-center shadow">
                    <i class="fas fa-users"></i>
                </div>
                <div>
                    <p class="text-[10px] text-gray-500 uppercase font-bold">Đối tượng</p>
                    <p class="font-heading font-bold text-blue-800 text-sm">Toàn thể CBNV Ban KTM</p>
                </div>
            </div>
        </div>

        <!-- CHỦ ĐỀ DỰ THI -->
        <div class="py-8 px-6 md:px-10">
            <h3 class="font-heading text-xl font-bold text-center text-gray-800 mb-6 uppercase tracking-wide border-b-2 border-blue-600 w-fit mx-auto pb-1">Chủ đề dự thi</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-orange-50 border-l-4 border-orange-500 p-4 rounded-r-lg shadow-sm">
                    <div class="flex items-center gap-2 mb-2">
                        <i class="fas fa-hard-hat text-orange-500 text-xl"></i>
                        <h4 class="font-bold text-gray-800 text-sm">Nét đẹp lao động</h4>
                    </div>
                    <p class="text-[11px] text-gray-600 leading-relaxed italic">Lao động an toàn, tuân thủ quy trình, sáng tạo và chuyên nghiệp tại các vị trí công tác.</p>
                </div>
                <div class="bg-pink-50 border-l-4 border-pink-500 p-4 rounded-r-lg shadow-sm">
                    <div class="flex items-center gap-2 mb-2">
                        <i class="fas fa-home text-pink-500 text-xl"></i>
                        <h4 class="font-bold text-gray-800 text-sm">Hạnh phúc gia đình</h4>
                    </div>
                    <p class="text-[11px] text-gray-600 leading-relaxed italic">Khoảnh khắc bình yên, sự quan tâm chia sẻ trong đời sống thường ngày của đoàn viên.</p>
                </div>
            </div>
        </div>

        <!-- YÊU CẦU TÁC PHẨM -->
        <div class="py-6 px-6 md:px-10 bg-white border-t border-gray-100">
            <h3 class="font-heading text-lg font-bold text-[#1e293b] mb-4 flex items-center gap-2 uppercase tracking-wide">
                <i class="fas fa-file-contract text-blue-600"></i> Yêu cầu tác phẩm
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-3 text-[11px] text-gray-700">
                <div class="flex items-start gap-2">
                    <i class="fas fa-check text-green-500 mt-1"></i>
                    <span>Định dạng: <strong>.png</strong> hoặc <strong>.jpg</strong>; tối thiểu <strong>1.920 pixel</strong>.</span>
                </div>
                <div class="flex items-start gap-2">
                    <i class="fas fa-check text-green-500 mt-1"></i>
                    <span>Dung lượng tối đa <strong>10MB</strong>. Không chấp nhận ảnh tạo bằng AI.</span>
                </div>
                <div class="flex items-start gap-2">
                    <i class="fas fa-check text-green-500 mt-1"></i>
                    <span>Chỉnh sửa sáng/màu được phép nhưng không làm thay đổi bản chất nội dung.</span>
                </div>
                <div class="flex items-start gap-2">
                    <i class="fas fa-check text-green-500 mt-1"></i>
                    <span>Ưu tiên trang phục thương hiệu <strong>VNPT</strong>, lịch sự, đúng thuần phong mỹ tục.</span>
                </div>
            </div>
        </div>

        <!-- CƠ CẤU GIẢI THƯỞNG -->
        <div class="bg-gray-50/50 py-10 px-6 md:px-10 border-t border-gray-100">
            <h3 class="font-heading text-xl font-bold text-center text-[#1e293b] mb-8 uppercase tracking-wide">Giải thưởng cấp Ban</h3>
            <div class="space-y-4">
                <div class="flex items-center justify-between bg-white rounded-2xl border-2 border-[#fcd34d] p-5 shadow-sm">
                    <div class="flex items-center gap-4">
                        <div class="bg-[#fef3c7] text-[#b45309] h-14 w-14 rounded-full flex items-center justify-center text-2xl shadow-inner">
                            <i class="fas fa-trophy"></i>
                        </div>
                        <span class="text-xl font-bold text-[#1e293b]">01 Giải Nhất</span>
                    </div>
                    <div class="text-2xl font-heading font-extrabold text-[#b45309]">2.000.000đ</div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="flex items-center justify-between bg-white rounded-2xl border border-gray-200 p-4 shadow-sm">
                        <div class="flex items-center gap-3">
                            <div class="bg-gray-100 text-gray-500 h-10 w-10 rounded-full flex items-center justify-center text-lg">
                                <i class="fas fa-medal"></i>
                            </div>
                            <span class="font-bold text-sm text-[#1e293b]">02 Giải Nhì</span>
                        </div>
                        <div class="font-heading font-bold text-[#1e293b]">1.500.000đ</div>
                    </div>
                    <div class="flex items-center justify-between bg-white rounded-2xl border border-[#fed7aa] p-4 shadow-sm">
                        <div class="flex items-center gap-3">
                            <div class="bg-[#ffedd5] text-[#c2410c] h-10 w-10 rounded-full flex items-center justify-center text-lg">
                                <i class="fas fa-award"></i>
                            </div>
                            <span class="font-bold text-sm text-[#1e293b]">05 Giải Ba</span>
                        </div>
                        <div class="font-heading font-bold text-[#c2410c]">1.000.000đ</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- FOOTER -->
        <div class="footer-bg text-white py-8 px-8 md:px-12">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-3">
                    <h4 class="font-heading font-extrabold text-blue-400 uppercase text-[10px]">Đầu mối nộp bài</h4>
                    <p class="text-gray-300 text-[11px]">Các CĐBP tổng hợp bài dự thi gửi về Công đoàn Ban KTM.</p>
                    <p class="text-[#facc15] font-bold italic text-[10px] leading-snug">*(Mỗi CĐBP tối đa 06 tác phẩm: 3 LĐ & 3 GĐ)*</p>
                </div>
                <div class="space-y-2">
                    <h4 class="font-heading font-extrabold text-blue-400 uppercase text-[10px]">Hỗ trợ kỹ thuật</h4>
                    <p class="text-sm font-bold">Đ/c Hà Minh Hoàng</p>
                    <p class="text-gray-400 text-[11px]">SĐT: 0914.746.789 | Email: haminhhoang@vnpt.vn</p>
                </div>
            </div>
        </div>
    </div>

    <!-- AI SUBMISSION ASSISTANT -->
    <div class="max-w-2xl w-full mt-10 space-y-6 no-print">
        <div class="bg-white rounded-3xl shadow-xl overflow-hidden border-2 border-blue-500 ai-glow">
            <div class="bg-blue-600 p-4 text-white flex items-center justify-between shadow-md">
                <h3 class="font-heading font-bold uppercase tracking-widest flex items-center gap-2">
                    <i class="fas fa-magic"></i> Trợ lý AI - Nộp bài trực tuyến
                </h3>
                <span class="bg-blue-400/30 px-3 py-1 rounded-full text-[10px] font-bold">ONLINE SUBMIT</span>
            </div>
            
            <div class="p-6 space-y-6">
                <!-- Bước 1: Thông tin người dự thi -->
                <div class="space-y-4">
                    <h4 class="text-xs font-bold text-blue-800 uppercase flex items-center gap-2">
                        <span class="bg-blue-100 w-5 h-5 rounded-full flex items-center justify-center text-[10px]">1</span> 
                        Thông tin tác giả & Đơn vị
                    </h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="text-[10px] font-bold text-gray-400 uppercase mb-1 block">Tên tác giả *</label>
                            <input id="author-name" type="text" placeholder="Nhập họ và tên..." class="w-full px-4 py-2 border border-gray-200 rounded-xl outline-none focus:border-blue-500 transition-all">
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-gray-400 uppercase mb-1 block">CĐBP *</label>
                            <select id="author-unit" class="w-full px-4 py-2 border border-gray-200 rounded-xl outline-none focus:border-blue-500 bg-white">
                                <option value="">-- Chọn đơn vị --</option>
                                <option value="NOC1">NOC1</option><option value="NOC2">NOC2</option><option value="NOC3">NOC3</option>
                                <option value="KHKT">KHKT</option><option value="NSHC">NSHC</option><option value="ANM">ANM</option>
                                <option value="SOC">SOC</option><option value="NMC">NMC</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Bước 2: Tải ảnh -->
                <div class="space-y-4">
                    <h4 class="text-xs font-bold text-blue-800 uppercase flex items-center gap-2">
                        <span class="bg-blue-100 w-5 h-5 rounded-full flex items-center justify-center text-[10px]">2</span> 
                        Tải lên ảnh dự thi
                    </h4>
                    <div id="drop-area" class="border-2 border-dashed border-blue-100 rounded-2xl p-6 text-center bg-blue-50/20 hover:bg-blue-50 transition-all cursor-pointer relative overflow-hidden group">
                        <input type="file" id="file-input" accept="image/*" class="hidden" onchange="handleFileUpload(this)">
                        <label for="file-input" class="cursor-pointer block">
                            <i class="fas fa-image text-4xl text-blue-300 group-hover:text-blue-500 transition-colors mb-2"></i>
                            <p class="text-sm text-gray-500 font-medium">Chọn ảnh gửi về Drive</p>
                        </label>
                        <div id="image-preview" class="mt-4 hidden">
                            <img id="preview-img" src="" class="max-h-56 mx-auto rounded-xl shadow-lg border-4 border-white">
                        </div>
                    </div>
                </div>

                <!-- Bước 3: Thông tin bài dự thi -->
                <div id="ai-analysis" class="hidden space-y-4 animate-fade-in bg-slate-50 p-5 rounded-2xl border border-slate-100">
                    <div class="flex items-center justify-between">
                        <h4 class="text-xs font-bold text-blue-800 uppercase flex items-center gap-2">
                            <span class="bg-blue-200 w-5 h-5 rounded-full flex items-center justify-center text-[10px]">3</span> 
                            Chi tiết tác phẩm
                        </h4>
                        <div id="ai-status" class="flex items-center gap-1 text-[10px] font-bold text-blue-600 bg-blue-50 px-2 py-1 rounded-lg">
                            <i class="fas fa-magic animate-pulse"></i> AI Gợi ý nội dung
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="text-[10px] font-bold text-gray-500 uppercase block mb-1">Chủ đề</label>
                                <span id="ai-category-badge" class="inline-block px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide"></span>
                            </div>
                            <div>
                                <label class="text-[10px] font-bold text-gray-500 uppercase block mb-1">Tên tác phẩm *</label>
                                <input id="photo-title" type="text" placeholder="Tên ảnh..." class="w-full bg-white px-3 py-2 border border-gray-200 rounded-lg text-sm font-bold text-gray-800 outline-none focus:ring-2 focus:ring-blue-400">
                            </div>
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-gray-500 uppercase block mb-1">Lời bình về tác phẩm *</label>
                            <textarea id="photo-caption" rows="4" class="w-full bg-white px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-700 outline-none focus:ring-2 focus:ring-blue-400"></textarea>
                        </div>
                    </div>
                </div>

                <button onclick="submitEntry()" id="btn-submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-2xl shadow-xl shadow-blue-100 transition-all transform hover:-translate-y-1 flex items-center justify-center gap-3">
                    <i class="fas fa-cloud-upload-alt"></i> NỘP BÀI VÀ LƯU VÀO DRIVE
                </button>
            </div>
        </div>
    </div>

    <!-- Modal thành công -->
    <div id="success-modal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-3xl p-10 max-w-sm w-full text-center shadow-2xl animate-fade-in">
            <div class="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center text-4xl mx-auto mb-6">
                <i class="fas fa-check"></i>
            </div>
            <h4 class="text-xl font-heading font-bold text-slate-800 mb-2">Đã nhận bài dự thi!</h4>
            <p class="text-slate-500 text-sm mb-6">Ảnh của bạn đã được chuyển thẳng vào Drive ban tổ chức. Cảm ơn đồng chí!</p>
            <button onclick="closeModal()" class="w-full bg-slate-800 text-white font-bold py-3 rounded-xl hover:bg-black transition-colors">Đóng</button>
        </div>
    </div>

    <script>
        const apiKey = ""; 
        // DÁN WEB APP URL CỦA BẠN VÀO ĐÂY SAU KHI DEPLOY GOOGLE SCRIPT
        const GOOGLE_SCRIPT_URL = "URL_WEB_APP_CUA_BAN"; 
        let currentImageData = null;

        async function callGemini(prompt, isImage = false, imageData = null) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            let contents = [{ parts: [{ text: prompt }] }];
            if (isImage && imageData) {
                contents[0].parts.push({ inlineData: { mimeType: "image/png", data: imageData.split(',')[1] } });
            }

            const payload = {
                contents: contents,
                systemInstruction: { parts: [{ text: "Phân tích ảnh cuộc thi VNPT. Trả JSON: { category, title, caption }." }] },
                generationConfig: { responseMimeType: "application/json" }
            };

            try {
                const response = await fetch(url, { method: 'POST', body: JSON.stringify(payload) });
                const result = await response.json();
                return JSON.parse(result.candidates[0].content.parts[0].text);
            } catch (e) {
                return { category: "Nét đẹp lao động", title: "Tác phẩm dự thi", caption: "Bức ảnh ghi lại khoảnh khắc lao động ý nghĩa của tôi tại đơn vị." };
            }
        }

        async function handleFileUpload(input) {
            const file = input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = async (e) => {
                currentImageData = e.target.result;
                document.getElementById('preview-img').src = currentImageData;
                document.getElementById('image-preview').classList.remove('hidden');
                document.getElementById('ai-analysis').classList.remove('hidden');
                
                const analysis = await callGemini("Gợi ý nội dung cho ảnh dự thi này.", true, currentImageData);
                
                const catBadge = document.getElementById('ai-category-badge');
                catBadge.innerText = analysis.category;
                catBadge.className = "inline-block px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide " + 
                                    (analysis.category.includes("lao động") ? "bg-orange-100 text-orange-600" : "bg-pink-100 text-pink-600");
                
                document.getElementById('photo-title').value = analysis.title;
                document.getElementById('photo-caption').value = analysis.caption;
            };
            reader.readAsDataURL(file);
        }

        async function submitEntry() {
            const name = document.getElementById('author-name').value;
            const unit = document.getElementById('author-unit').value;
            const title = document.getElementById('photo-title').value;
            const caption = document.getElementById('photo-caption').value;
            const btn = document.getElementById('btn-submit');
            
            if(!name || !unit || !title || !currentImageData) {
                alert("Vui lòng điền đủ tên, đơn vị và chọn ảnh!");
                return;
            }

            if(GOOGLE_SCRIPT_URL === "URL_WEB_APP_CUA_BAN") {
                alert("Thông báo: Bạn cần thiết lập URL Web App Google Script để ảnh có thể lưu vào Drive thực tế.");
                document.getElementById('success-modal').classList.remove('hidden');
                return;
            }

            btn.disabled = true;
            btn.classList.add('loading');
            btn.innerHTML = '<i class="fas fa-spinner animate-spin"></i> ĐANG TẢI LÊN DRIVE...';

            try {
                const response = await fetch(GOOGLE_SCRIPT_URL, {
                    method: 'POST',
                    mode: 'no-cors', // Dùng no-cors cho Google Script đơn giản
                    cache: 'no-cache',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        author: name,
                        unit: unit,
                        title: title,
                        caption: caption,
                        image: currentImageData
                    })
                });
                
                // Vì no-cors không đọc được response, chúng ta giả định thành công sau khi fetch xong
                document.getElementById('success-modal').classList.remove('hidden');
            } catch (e) {
                console.error(e);
                alert("Có lỗi xảy ra khi tải lên. Hãy kiểm tra kết nối mạng.");
            } finally {
                btn.disabled = false;
                btn.classList.remove('loading');
                btn.innerHTML = '<i class="fas fa-cloud-upload-alt"></i> NỘP BÀI VÀ LƯU VÀO DRIVE';
            }
        }

        function closeModal() {
            document.getElementById('success-modal').classList.add('hidden');
            location.reload();
        }

        function downloadInfographic() {
            const element = document.getElementById('infographic-main');
            html2canvas(element, { scale: 2, useCORS: true }).then(canvas => {
                const link = document.createElement('a');
                link.download = 'Infographic-VNPT-Net.png';
                link.href = canvas.toDataURL('image/png');
                link.click();
            });
        }
    </script>
</body>
</html>